# Unmounts and closes encrypted partitions if something fails
cleanup() {
  printf "%bCleaning up...%b\n" "${YELLOW}" "${NORMAL}"
  umount -R /mnt
  if [[ ${isEncrypted} ]]; then
    cryptsetup close "${luksName}"
  fi
}
trap cleanup EXIT

